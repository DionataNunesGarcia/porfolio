# Ignore directories generated by Composer and Node.
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/themes/custom/hsl/public
/web/libraries/
/web/profiles/

# Ignore Yarn files, except for the necessary ones to install dependencies.
.yarn/*
!.yarn/cache
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.yarn/install-state.gz

docroot/themes/custom/*/public/**
docroot/themes/custom/*/.tmp
# we're not using recipes in this project.
./recipes/

# Ignore sensitive information.
/web/sites/*/settings.local.php

# Ignore Drupal's file directory.
/web/sites/*/files/*

# Ignore specific development-related files or directories.
/private/
/drush/contrib/
.env
.idea/
.vscode/
.github/
.cursorrules
*.log
*.sql
*.tgz
*.zip
*.sql.gz
.DS_Store

# ddev
.ddev/config.local.yaml

# ignore the default site because we're on a multisite setup
/web/sites/default/
node_modules

# Dexa custom
/tasks/

# Tests results and cache
test-results/
playwright-report/
playwright/.cache/
